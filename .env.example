# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Vercel Postgres (use `vercel env pull .env.local` to populate)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Initial admin (used by `npm run db:seed-admin`)
ADMIN_EMAIL=admin@thepaddocksf.com
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Admin

# Email (Resend) — sign up at resend.com, verify a domain, paste an API key
RESEND_API_KEY=
FROM_EMAIL=bookings@thepaddocksf.com
APP_URL=http://localhost:3000

# Cron — generate with: openssl rand -base64 32
CRON_SECRET=
